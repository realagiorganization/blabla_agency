# Ignore everything except the explicit repository scaffold.
*
!.gitignore
!.gitattributes
!.yamllint.yml
!AGENTS.md
!AGENTS.md.d/
!AGENTS.md.d/**
!README.md
!Makefile
!index.html
!requirements-docs.txt
!requirements-dev.txt
!package.json
!package-lock.json
!tsconfig.json
!vite.config.ts
!vitest.config.ts
!.github/
!.github/workflows/
!.github/workflows/**
!.storybook/
!.storybook/**
!docs/
!docs/**
!scripts/
!scripts/**
!slides/
!slides/**
!src/
!src/**
!.codex/
!.codex/skills/
!.codex/skills/.gitkeep
!.codex/logs/
!.codex/logs/.gitkeep
!.codex/crash*
!.codex/crash*/
!.codex/crash*/**

# Generated outputs and local tooling.
build/
site/
.venv/
node_modules/
dist/
storybook-static/
.node_modules_stamp
coverage/
__pycache__/
*.pyc
.DS_Store

# Never track large installers or disk images.
*.AppImage
*.appimage
*.dmg
*.exe
*.msi
*.iso
*.img
*.qcow2
*.vmdk
*.vdi
